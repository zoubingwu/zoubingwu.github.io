---
import PostList from '../components/PostList.astro';
import { site } from '../config/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getAbsoluteUrl,
  getPaginatedPath,
  getSortedPosts,
  toPostListItem,
} from '../utils/posts';

const allPosts = await getSortedPosts();
const posts = allPosts.slice(0, site.paginate).map(toPostListItem);
const nextPagePath =
  allPosts.length > site.paginate ? getPaginatedPath(2) : undefined;
---

<BaseLayout
  seo={{
    title: site.name,
    description: site.description,
    url: getAbsoluteUrl('/'),
    next: nextPagePath ? getAbsoluteUrl(nextPagePath) : undefined,
  }}
>
  <PostList posts={posts} nextPagePath={nextPagePath} />
</BaseLayout>
